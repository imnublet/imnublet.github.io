---
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/site.js';
---
<Base title="Projects" current="projects" description="Selected projects across ML, quant, computer vision, and games.">
  <div class="wrap narrow">
    <section class="block">
      <p class="eyebrow">Selected work</p>
      <h2 style="font-size:1.9rem; margin:.2rem 0 .5rem">Projects</h2>
      <p style="color:var(--muted); max-width:34rem; margin:0 0 2rem">
        Five projects worth showing, spanning quantitative finance, on-device ML,
        computer vision, plugins, and language-emergence research. Each links to a
        writeup or the repo.
      </p>
      <div class="cards">
        {projects.map((p) => (
          <a class="card wide" href={p.writeup ?? p.repo ?? '#'}>
            <span class="kicker"><span>{p.kicker}</span><span class="state">{p.state}</span></span>
            <h3>{p.name}</h3>
            <p>{p.blurb}</p>
            <span class="tags">
              {p.tags}
              {p.writeup && <> &nbsp;— read the writeup →</>}
              {!p.writeup && p.repo && <> &nbsp;— view on GitHub →</>}
            </span>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>
