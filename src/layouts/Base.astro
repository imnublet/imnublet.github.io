---
import '../styles/global.css';
const { title, description, current } = Astro.props;
const nav = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/projects/', label: 'Projects', key: 'projects' },
  { href: '/blog/', label: 'Writing', key: 'blog' },
];
const site = 'Sayf El Kaddouri';
const desc = description ?? 'ML / applied-research engineer — field notes and projects.';
---
<!-- head is injected by Astro; content below is the page body -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={desc} />
<title>{title ? `${title} · ${site}` : site}</title>

<script is:inline>
  // Apply saved theme before paint to avoid flash; default follows the OS.
  (function () {
    try {
      var t = localStorage.getItem('theme');
      if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
    } catch (e) {}
  })();
</script>

<header class="nav">
  <div class="wrap row">
    <a class="brand" href="/"><span class="dot"></span>SEK / instrument</a>
    <nav>
      {nav.map((n) => (
        <a href={n.href} aria-current={current === n.key ? 'page' : undefined}>{n.label}</a>
      ))}
      <button class="theme-btn" id="theme-toggle" type="button" aria-label="Toggle colour theme">Theme</button>
    </nav>
  </div>
</header>

<main>
  <slot />
</main>

<footer class="site">
  <div class="wrap" style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; width:100%">
    <span>{site}</span>
    <span>
      <a href="https://github.com/imnublet">github</a> &nbsp;·&nbsp;
      <a href="/blog/">writing</a> &nbsp;·&nbsp;
      <a href="/projects/">projects</a>
    </span>
    <span>Built with Astro</span>
  </div>
</footer>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    var root = document.documentElement;
    function current() {
      return root.getAttribute('data-theme')
        || (window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light');
    }
    btn.addEventListener('click', function () {
      var next = current() === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    });
  })();
</script>
