---
import Base from '../layouts/Base.astro';
import Trace from '../components/Trace.astro';
import { posts, projects } from '../data/site.js';
const featured = projects.filter((p) => p.state === 'polished' || p.name === 'RunningFatigueAI').slice(0, 4);
const latest = posts.slice(0, 4);
---
<Base current="home">
  <section class="hero">
    <Trace />
    <div class="wrap inner">
      <p class="eyebrow">ML / Applied Research</p>
      <h1>I build instruments for problems that don’t come with a dial.</h1>
      <p>Machine-learning and applied-research engineer. I work across quantitative
        finance, on-device ML, computer vision, and language emergence — and I write
        the field notes to match.</p>
      <div class="links">
        <a href="/projects/">→ Projects</a>
        <a href="/blog/">→ Writing</a>
        <a href="https://github.com/imnublet">→ GitHub</a>
      </div>
    </div>
  </section>

  <div class="wrap">
    <section class="block">
      <p class="sec"><span class="n">§</span> Selected work</p>
      <h2>Projects</h2>
      <div class="cards">
        {featured.map((p) => (
          <a class={`card${p.wide ? ' wide' : ''}`} href={p.writeup ?? p.repo ?? '/projects/'}>
            <span class="kicker"><span>{p.kicker}</span><span class="state">{p.state}</span></span>
            <h3>{p.name}</h3>
            <p>{p.blurb}</p>
            <span class="tags">{p.tags}</span>
          </a>
        ))}
      </div>
      <p style="margin-top:1.2rem"><a href="/projects/">All projects →</a></p>
    </section>

    <section class="block" style="border-top:1px solid var(--rule)">
      <p class="sec"><span class="n">§</span> Field notes</p>
      <h2>Recent writing</h2>
      <ul class="postlist">
        {latest.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/`}>
              <span class="date">{post.date}</span>
              <span>
                <h3>{post.title}</h3>
                <p>{post.deck}</p>
                <div class="row-tags">{post.tags.join(' · ')}</div>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Base>
