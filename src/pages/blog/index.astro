---
import Base from '../../layouts/Base.astro';
import { posts } from '../../data/site.js';
---
<Base title="Writing" current="blog" description="Field notes on quant, on-device ML, computer vision, and emergent language.">
  <div class="wrap narrow">
    <section class="block">
      <p class="eyebrow">Field Notes</p>
      <h2 style="font-size:1.9rem; margin:.2rem 0 .5rem">Writing</h2>
      <p style="color:var(--muted); max-width:34rem; margin:0 0 1.5rem">
        Working notes from the projects — the methods I trust, and why. Rigorous
        where it counts, readable throughout.
      </p>
      <ul class="postlist">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/`}>
              <span class="date">{post.date}</span>
              <span>
                <h3>{post.title}</h3>
                <p>{post.deck}</p>
                <div class="row-tags">{post.project} &nbsp;·&nbsp; {post.readtime} &nbsp;·&nbsp; {post.tags.join(' · ')}</div>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Base>
